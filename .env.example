# API Configuration - Example
# Copy this file to .env and update the values

# Production API URLs (use these in production)
VITE_API_URL=https://api.alleventpictures.com/api/v1
VITE_WS_URL=wss://api.alleventpictures.com/api/v1/ws

# Development API URLs (uncomment for local development)
# VITE_API_URL=http://localhost:8082/api/v1
# VITE_WS_URL=ws://localhost:8082/api/v1/ws
